# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require&connect_timeout=10&statement_timeout=30000&idle_in_transaction_session_timeout=30000&max_retries=3"
DATABASE_URL_UNPOOLED="your_unpooled_url"
PGDATABASE="your_database_name"
PGHOST="your_host"
PGHOST_UNPOOLED="your_unpooled_host"
PGPASSWORD="your_password"
PGUSER="your_username"
POSTGRES_DATABASE="your_database_name"
POSTGRES_HOST="your_host"
POSTGRES_PASSWORD="your_password"
POSTGRES_PRISMA_URL="postgresql://user:password@host:port/dbname?sslmode=require&pgbouncer=true&connect_timeout=10&statement_timeout=30000&idle_in_transaction_session_timeout=30000&max_retries=3"
POSTGRES_URL="your_postgres_url"
POSTGRES_URL_NON_POOLING="your_non_pooling_url"
POSTGRES_URL_NO_SSL="your_no_ssl_url"
POSTGRES_USER="your_username"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="your-production-url"
NEXT_PUBLIC_API_URL="your-production-url"

